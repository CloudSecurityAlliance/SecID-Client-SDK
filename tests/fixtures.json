    {
      "name": "client_timeout",
      "description": "Mock server hangs. Client should return error within its timeout period.",
      "category": "client_error",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-2021-44228",
        "method": "resolve"
      },
      "mock_response": {
        "behavior": "timeout"
      },
      "expected": {
        "raises_error": true,
        "error_contains": "timeout"
      }
    },
    {
      "name": "client_oversized_response",
      "description": "Mock returns >10MB body. Client should reject it.",
      "category": "client_error",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-2021-44228",
        "method": "resolve"
      },
      "mock_response": {
        "behavior": "oversized_body",
        "body_size_bytes": 11000000
      },
      "expected": {
        "raises_error": true
      }
    },
    {
      "name": "client_invalid_json",
      "description": "Server returns non-JSON (HTML error page). Client should return error, not crash.",
      "category": "client_error",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-2021-44228",
        "method": "resolve"
      },
      "mock_response": {
        "http_status": 200,
        "raw_body": "<html><body>Bad Gateway</body></html>",
        "content_type": "text/html"
      },
      "expected": {
        "raises_error": true
      }
    },
    {
      "name": "client_http_500",
      "description": "Server returns 500 with JSON error body. Client handles gracefully.",
      "category": "client_error",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-2021-44228",
        "method": "resolve"
      },
      "mock_response": {
        "http_status": 500,
        "body": {
          "secid_query": "secid:advisory/mitre.org/cve#CVE-2021-44228",
          "status": "error",
          "results": [],
          "message": "Internal server error"
        }
      },
      "expected": {
        "raises_error": true
      }
    },
    {
      "name": "client_http_500_non_json",
      "description": "Server returns 500 with HTML body. Client handles gracefully.",
      "category": "client_error",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-2021-44228",
        "method": "resolve"
      },
      "mock_response": {
        "http_status": 500,
        "raw_body": "<html><body>Internal Server Error</body></html>",
        "content_type": "text/html"
      },
      "expected": {
        "raises_error": true
      }
    },
    {
      "name": "client_network_error",
      "description": "Connection refused (no server listening). Client returns error.",
      "category": "client_error",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-2021-44228",
        "method": "resolve"
      },
      "mock_response": {
        "behavior": "connection_refused"
      },
      "expected": {
        "raises_error": true
      }
    },
    {
      "name": "empty_results_array",
      "description": "Server says 'found' but results=[] (shouldn't happen, but client shouldn't crash).",
      "category": "edge_case",
      "input": {
        "secid": "secid:advisory/mitre.org/cve#CVE-9999-0001",
        "method": "resolve"
      },
      "mock_response": {
        "http_status": 200,
        "body": {
          "secid_query": "secid:advisory/mitre.org/cve#CVE-9999-0001",
          "status": "found",
          "results": [],
          "message": null
        }
      },
      "expected": {
        "status": "found",
        "best_url": null,
        "was_corrected": false,
        "resolution_result_count": 0,
        "registry_result_count": 0,
        "message": null
      }
    },
    {
      "name": "best_url_on_registry_only",
      "description": "Results have only data fields (registry results), no weight/url. best_url should be null.",
      "category": "edge_case",
      "input": {
        "secid": "secid:control/nist.gov/csf@2.0",
        "method": "resolve"
      },
      "mock_response": {
        "http_status": 200,
        "body": {
          "secid_query": "secid:control/nist.gov/csf@2.0",
          "status": "found",
          "results": [
            {
              "secid": "secid:control/nist.gov/csf@2.0",
              "data": {
                "official_name": "NIST Cybersecurity Framework v2.0",
                "urls": [{"type": "website", "url": "https://www.nist.gov/cyberframework"}],
                "patterns": ["^[A-Z]{2}(\\.[A-Z]{2})?(-\\d+)?$"],
                "examples": ["GV.OC-1", "PR.AC-1"]
              }
            }
          ],
          "message": null
        }
      },
      "expected": {
        "status": "found",
        "best_url": null,
        "was_corrected": false,
        "resolution_result_count": 0,
        "registry_result_count": 1,
        "message": null
      }
    },
